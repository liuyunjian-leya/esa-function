{
  "name": "fullstack-react-express",

  // 前端构建（vite）
  "installCommand": "npm install",
  "buildCommand": "npm run build",

  // 静态资源（前端构建产物）
  "assets": {
    "directory": "./dist",
    "notFoundStrategy": "singlePageApplication"
  },

  // ER 函数入口（V8 isolate runtime）
  "entry": "./edge.ts",

  // 路由分发：列表里的路由走 ER，其它由平台兜底（命中静态走 assets，否则走后端容器）
  "edgeFunctionFirst": ["/edge/*", "/promo/*"]
}
